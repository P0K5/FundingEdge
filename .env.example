# MeteoEdge environment configuration
# Copy to .env and fill in your values. Never commit .env.

# ---------------------------------------------------------------------------
# Polymarket CLOB (required for --live mode)
# ---------------------------------------------------------------------------

# L1: your wallet private key — hex string, no 0x prefix
POLYMARKET_API_KEY=your_private_key_here

# L2: derived once from the L1 key via client.create_or_derive_api_creds()
# Run: python3 -c "from py_clob_client.client import ClobClient; import os; c = ClobClient('https://clob.polymarket.com', key=os.environ['POLYMARKET_API_KEY'], chain_id=137); cr = c.create_or_derive_api_creds(); print(cr.api_key, cr.api_secret, cr.api_passphrase)"
POLYMARKET_L2_API_KEY=your_l2_api_key_here
POLYMARKET_L2_API_SECRET=your_l2_api_secret_here
POLYMARKET_L2_API_PASSPHRASE=your_l2_api_passphrase_here

# 137 = Polygon mainnet (real money), 80002 = Amoy testnet (safe to test)
POLYMARKET_CHAIN_ID=137

# Leave at default unless you need to point at a staging environment
# POLYMARKET_HOST=https://clob.polymarket.com

# ---------------------------------------------------------------------------
# Strategy
# ---------------------------------------------------------------------------

# Minimum edge in cents to flag a candidate (default: 15)
# MIN_EDGE_CENTS=15.0

# Enable YES-side trades — disabled until ≥7 days of settlements validate accuracy
# Re-enable with: ENABLE_YES_TRADES=true
ENABLE_YES_TRADES=false

# ---------------------------------------------------------------------------
# Position sizing & risk limits
# ---------------------------------------------------------------------------

# EUR staked per trade (default: 5.0)
POSITION_SIZE_EUR=5.0

# Starting capital — used as reference for drawdown calculation (default: 500.0)
# Week 1 live: set to 100.0
STARTING_CAPITAL_EUR=100.0

# Stop trading for the day if daily loss exceeds this (default: 50.0)
# Week 1 live: set to 10.0 (10% of week 1 capital)
RISK_DAILY_LOSS_LIMIT_EUR=10.0

# Max simultaneous open positions (default: 15)
# RISK_MAX_OPEN_POSITIONS=15

# Stop all trading if drawdown exceeds this fraction of starting capital (default: 0.15 = 15%)
# RISK_DRAWDOWN_STOP_PCT=0.15

# Minimum combined order book size to accept a trade (default: 50 contracts)
# RISK_MIN_LIQUIDITY=50

# ---------------------------------------------------------------------------
# Operational
# ---------------------------------------------------------------------------

# Poll interval in seconds (default: 300 = 5 minutes)
# POLL_INTERVAL_SECONDS=300

# Enable live CLOB orderbook enrichment per bracket — more accurate prices,
# but adds ~2 API calls per candidate per poll (default: false)
# ENABLE_CLOB_ENRICHMENT=false
